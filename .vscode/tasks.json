{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create Build Dir",
      "type": "shell",
      "command": "cmd",
      "args": ["/C", "if not exist build mkdir build"],
      "problemMatcher": []
    },
    {
      "type": "cppbuild",
      "label": "C/C++: cl.exe build active file",
      "command": "cl.exe",
      "args": [
        "/Zi",
        "/EHsc",
        "/nologo",
        "user32.lib",
        "/Fe:", "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
        "/Fo:", "${workspaceFolder}\\build\\",
        "/Fd:", "${workspaceFolder}\\build\\",
        "${file}",
        "/link",
        "/SUBSYSTEM:WINDOWS"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Create Build Dir",
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ]
}
